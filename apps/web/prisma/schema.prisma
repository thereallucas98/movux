generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Enums
// ============================================================================

enum Role {
  CUSTOMER
  CARRIER
  ADMIN
}

// Shared by carrierProfile, company and carrierDocument. Not every value
// applies to every model (e.g. company never uses SUSPENDED) — that's fine,
// unused enum members cost nothing.
enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ShipmentStatus {
  DRAFT
  OPEN
  PROPOSALS_RECEIVED
  CARRIER_SELECTED
  COLLECTED
  IN_TRANSIT
  DELIVERED
  REVIEWED
  CANCELLED
  EXPIRED
}

enum ShipmentType {
  RESIDENTIAL_MOVING
  COMMERCIAL_FREIGHT
  DELIVERY
  OTHER
}

// S10-T1: sobrevive só por causa de pricingTemplate.vehicleType, que o
// pricing engine sempre lê como 'ANY' (nunca o valor real do frete) — ver
// docs/tasks/s10-t1-fleet-taxonomy/exploration.md. Vehicle.type e
// Shipment.vehicleTypeRequired migraram pra VehicleCategory/VehicleSpec.
enum VehicleType {
  ANY
  MOTORCYCLE
  VAN
  TRUCK_SMALL
  TRUCK_LARGE
}

enum ProposalStatus {
  ACTIVE
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum SignalType {
  COMPLETED
  CARRIER_REJECTED
  CUSTOMER_REJECTED
}

enum PlanCode {
  FREE
  PRO_MONTHLY
  PRO_SEMESTER
  PRO_ANNUAL
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

// Also reused by safetyCheckIn.role and reviewTag.targetRole (both CUSTOMER|CARRIER only).
enum ReviewerRole {
  CUSTOMER
  CARRIER
}

enum ModifierCode {
  FLOOR
  HELPER
  DISASSEMBLY
  PACKING
  DIFFICULT_ACCESS
  NIGHT_WEEKEND
}

enum NeighborhoodClassification {
  POPULAR
  MIDDLE
  UPSCALE
}

enum TimeWindow {
  MORNING
  AFTERNOON
  EVENING
  SPECIFIC
}

enum AddressType {
  ORIGIN
  DESTINATION
}

enum ModifierValueType {
  FIXED
  PERCENTAGE
}

enum SubscriberType {
  CARRIER
  COMPANY
}

enum QueueEntryStatus {
  WAITING
  CALLED
  ACTIVE
  EXHAUSTED
  WITHDRAWN
}

enum ResponseType {
  PENDING
  ACCEPTED
  REJECTED
}

enum EventType {
  PUBLISHED
  CARRIER_CALLED
  PROPOSAL_RECEIVED
  PROPOSAL_REJECTED
  CARRIER_SELECTED
  SAFETY_CONFIRMED
  COLLECTED
  IN_TRANSIT
  DELIVERED
  WINDOW_ALERT
  CANCELLED
  EXPIRED
}

enum CompanyMemberRole {
  OWNER
  MANAGER
  DRIVER
}

enum CarrierDocumentType {
  CPF
  CNH_FRONT
  CNH_BACK
  ADDRESS_PROOF
  SELFIE
  CNPJ
  SOCIAL_CONTRACT
}

enum BillingCycle {
  MONTHLY
  SEMESTER
  ANNUAL
  CUSTOM
}

enum LastTrigger {
  VOLUME
  DEVIATION
  TIME
  MANUAL
}

// Not in the original enum list (DATABASE-DESIGN.md §4.3 subscriptionPayment.status)
// but required to map the field faithfully — PENDING/APPROVED/REJECTED overlap
// with VerificationStatus, REFUNDED does not, so it needs its own enum.
enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

// Not in the original enum list (DATABASE-DESIGN.md §11.1 notificationLog.status).
enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

// ============================================================================
// Geography (DATABASE-DESIGN.md §5)
// ============================================================================

model State {
  id       String @id @default(uuid())
  name     String
  uf       String @unique @db.Char(2)
  ibgeCode String @map("ibge_code")

  cities City[]

  @@map("state")
}

model City {
  id       String  @id @default(uuid())
  stateId  String  @map("state_id")
  name     String
  ibgeCode String  @unique @map("ibge_code")
  isActive Boolean @default(true) @map("is_active")

  state                State                 @relation(fields: [stateId], references: [id], onDelete: Restrict)
  neighborhoods        Neighborhood[]
  neighborhoodClusters NeighborhoodCluster[]
  pricingModifiers     PricingModifier[]
  shipmentAddresses    ShipmentAddress[]

  @@map("city")
}

model Neighborhood {
  id             String                     @id @default(uuid())
  cityId         String                     @map("city_id")
  name           String
  classification NeighborhoodClassification
  ibgeCode       String?                    @map("ibge_code")

  city               City                  @relation(fields: [cityId], references: [id], onDelete: Restrict)
  clusterMemberships ClusterNeighborhood[]
  shipmentAddresses  ShipmentAddress[]

  @@unique([cityId, name])
  @@map("neighborhood")
}

model NeighborhoodCluster {
  id     String @id @default(uuid())
  cityId String @map("city_id")
  name   String
  slug   String

  city                          City                  @relation(fields: [cityId], references: [id], onDelete: Restrict)
  neighborhoods                 ClusterNeighborhood[]
  pricingTemplatesAsOrigin      PricingTemplate[]     @relation("PricingTemplateOrigin")
  pricingTemplatesAsDestination PricingTemplate[]     @relation("PricingTemplateDestination")

  @@unique([cityId, slug])
  @@map("neighborhoodCluster")
}

model ClusterNeighborhood {
  clusterId      String @map("cluster_id")
  neighborhoodId String @map("neighborhood_id")

  cluster      NeighborhoodCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  neighborhood Neighborhood        @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)

  @@id([clusterId, neighborhoodId])
  @@map("clusterNeighborhood")
}

// ============================================================================
// Identity (DATABASE-DESIGN.md §3)
// ============================================================================

// Email verification required before any action; role is immutable after
// creation (changing role requires a new account) — both enforced at the
// use-case layer, not the DB.
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  fullName        String    @map("full_name")
  passwordHash    String    @map("password_hash")
  role            Role
  emailVerifiedAt DateTime? @map("email_verified_at")
  avatarUrl       String?   @map("avatar_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  customerProfile          CustomerProfile?
  carrierProfile           CarrierProfile?        @relation("CarrierProfileUser")
  carrierProfilesVerified  CarrierProfile[]       @relation("CarrierProfileVerifier")
  companiesOwned           Company[]              @relation("CompanyOwner")
  companiesVerified        Company[]              @relation("CompanyVerifier")
  companyMemberships       CompanyMembership[]
  vehicles                 Vehicle[]
  carrierDocuments         CarrierDocument[]      @relation("CarrierDocumentOwner")
  carrierDocumentsReviewed CarrierDocument[]      @relation("CarrierDocumentReviewer")
  carrierPricingConfigs    CarrierPricingConfig[]
  proposalQueueEntries     ProposalQueueEntry[]
  proposals                Proposal[]
  chatMessages             ChatMessage[]
  safetyCheckIns           SafetyCheckIn[]
  shipmentEventsTriggered  ShipmentEvent[]
  reviewsWritten           Review[]               @relation("ReviewAuthor")
  reviewsReceived          Review[]               @relation("ReviewSubject")
  notificationLogs         NotificationLog[]

  @@map("user")
}

// 1:1 extension of user where role = CUSTOMER.
model CustomerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  phone          String?
  avgRating      Decimal? @map("avg_rating") @db.Decimal(3, 2)
  totalShipments Int      @default(0) @map("total_shipments")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shipments             Shipment[]
  deliveryConfirmations DeliveryConfirmation[]

  @@map("customerProfile")
}

// 1:1 extension of user where role = CARRIER.
// avgRating < 4.0 -> isFlagged = true (admin flag); avgRating < 3.5 -> auto-suspend
// (isActive = false, one-way — does not auto-reactivate if avgRating rises back).
// Both thresholds enforced at the use-case layer, not the DB.
model CarrierProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique @map("user_id")
  cpf                String?            @unique
  phone              String
  bio                String?
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  verifiedAt         DateTime?          @map("verified_at")
  verifiedBy         String?            @map("verified_by")
  avgRating          Decimal?           @map("avg_rating") @db.Decimal(3, 2)
  totalShipments     Int                @default(0) @map("total_shipments")
  isActive           Boolean            @default(true) @map("is_active")
  isFlagged          Boolean            @default(false) @map("is_flagged")
  currentCompanyId   String?            @map("current_company_id")

  user           User     @relation("CarrierProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  verifier       User?    @relation("CarrierProfileVerifier", fields: [verifiedBy], references: [id], onDelete: SetNull)
  currentCompany Company? @relation(fields: [currentCompanyId], references: [id], onDelete: SetNull)

  @@index([verificationStatus])
  @@map("carrierProfile")
}

// ============================================================================
// Company & fleet (DATABASE-DESIGN.md §3.4-3.7)
// ============================================================================

model Company {
  id                 String             @id @default(uuid())
  cnpj               String             @unique
  legalName          String             @map("legal_name")
  tradeName          String?            @map("trade_name")
  ownerId            String             @map("owner_id")
  logoUrl            String?            @map("logo_url")
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  verifiedAt         DateTime?          @map("verified_at")
  verifiedBy         String?            @map("verified_by")
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  owner                 User                   @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  verifier              User?                  @relation("CompanyVerifier", fields: [verifiedBy], references: [id], onDelete: SetNull)
  memberships           CompanyMembership[]
  vehicles              Vehicle[]
  carrierDocuments      CarrierDocument[]
  carrierPricingConfigs CarrierPricingConfig[]
  carriersCurrentlyHere CarrierProfile[]

  @@map("company")
}

// Links a carrier user to a company with a role. "Active in one company at a
// time" (UNIQUE companyId+userId WHERE leftAt IS NULL) needs a partial index
// Prisma's schema DSL can't express — enforced at the use-case layer, same as
// the "exactly one OWNER per company" rule (DATABASE-DESIGN.md §3.5).
model CompanyMembership {
  id        String            @id @default(uuid())
  companyId String            @map("company_id")
  userId    String            @map("user_id")
  role      CompanyMemberRole
  joinedAt  DateTime          @default(now()) @map("joined_at")
  leftAt    DateTime?         @map("left_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("companyMembership")
}

// Taxonomia de frota (S10-T1) — categoria (ex. "Caminhão") → especificação
// com capacidade real (ex. "Caminhão Toco", maxWeightKg/maxVolumeM3).
// Substitui o enum VehicleType em Vehicle.type/Shipment.vehicleTypeRequired.
// Ver docs/tasks/s10-t1-fleet-taxonomy/research.md — decisão de 2 níveis,
// mesmo padrão estrutural do SpecialtyGroup/SpecialtyItem do build-track.
model VehicleCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  // Mapeia pro tipo de veículo da API da FIPE ('cars' | 'motorcycles' |
  // 'trucks') — usado só pra filtrar VehicleBrand por categoria, sem
  // relação FK direta (marcas/modelos são importados de fonte externa).
  fipeVehicleType String  @map("fipe_vehicle_type")
  isActive        Boolean @default(true) @map("is_active")

  specs     VehicleSpec[]
  shipments Shipment[]

  @@map("vehicleCategory")
}

// Catálogo real de marca/modelo (S10-T1, importado uma vez da API da FIPE
// — ver prisma/seed/vehicle-brands-models.ts) — evita que o carrier digite
// o mesmo fabricante de formas diferentes. Ortogonal a VehicleCategory/
// VehicleSpec: marca/modelo é identidade do veículo, categoria/spec é
// capacidade de carga.
model VehicleBrand {
  id              String  @id @default(uuid())
  fipeVehicleType String  @map("fipe_vehicle_type")
  name            String
  isActive        Boolean @default(true) @map("is_active")

  models VehicleModel[]

  @@unique([fipeVehicleType, name])
  @@map("vehicleBrand")
}

model VehicleModel {
  id       String  @id @default(uuid())
  brandId  String  @map("brand_id")
  name     String
  isActive Boolean @default(true) @map("is_active")

  brand    VehicleBrand @relation(fields: [brandId], references: [id], onDelete: Restrict)
  vehicles Vehicle[]

  @@unique([brandId, name])
  @@map("vehicleModel")
}

// Um veículo físico tem exatamente uma especificação real — frota mista é
// resolvida por várias linhas de Vehicle por dono, não many-to-many aqui.
model VehicleSpec {
  id          String  @id @default(uuid())
  categoryId  String  @map("category_id")
  name        String
  maxWeightKg Decimal @map("max_weight_kg") @db.Decimal(8, 2)
  maxVolumeM3 Decimal @map("max_volume_m3") @db.Decimal(8, 2)
  isActive    Boolean @default(true) @map("is_active")

  category VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  vehicles Vehicle[]

  @@unique([categoryId, name])
  @@map("vehicleSpec")
}

// Owned by a carrier (autônomo) or a company (frota) — exactly one of
// ownerId/companyId must be set, never both; enforced at the use-case layer
// (no DB CHECK constraint, per DATABASE-DESIGN.md §3.6).
model Vehicle {
  id           String   @id @default(uuid())
  ownerId      String?  @map("owner_id")
  companyId    String?  @map("company_id")
  // Sem @unique aqui de propósito (achado #17 da QA momento-zero): a placa
  // só precisa ser única entre veículos ATIVOS, pra liberar reuso depois de
  // desativar. Prisma não expressa unique index parcial (`WHERE is_active`)
  // na DSL — a constraint real é um índice parcial `vehicle_plate_active_unique_idx`
  // (`CREATE UNIQUE INDEX ... ON vehicle(plate) WHERE is_active`) aplicado
  // via SQL puro, fora do `db push`/migrate (que não sabe representá-lo);
  // reforçado também no use-case (`createVehicle`) checando vehicles ativos
  // antes do insert.
  plate        String
  specId       String   @map("spec_id")
  modelId      String   @map("model_id")
  year         Int
  crlvUrl      String?  @map("crlv_url")
  crlvApproved Boolean  @default(false) @map("crlv_approved")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  owner   User?        @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  company Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  spec    VehicleSpec  @relation(fields: [specId], references: [id], onDelete: Restrict)
  model   VehicleModel @relation(fields: [modelId], references: [id], onDelete: Restrict)

  @@map("vehicle")
}

model CarrierDocument {
  id                 String              @id @default(uuid())
  carrierId          String?             @map("carrier_id")
  companyId          String?             @map("company_id")
  type               CarrierDocumentType
  fileUrl            String              @map("file_url")
  externalValidation Json?               @map("external_validation")
  status             VerificationStatus  @default(PENDING)
  reviewedBy         String?             @map("reviewed_by")
  reviewedAt         DateTime?           @map("reviewed_at")
  rejectionReason    String?             @map("rejection_reason")
  uploadedAt         DateTime            @default(now()) @map("uploaded_at")

  carrier  User?    @relation("CarrierDocumentOwner", fields: [carrierId], references: [id], onDelete: Restrict)
  company  Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reviewer User?    @relation("CarrierDocumentReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@map("carrierDocument")
}

// ============================================================================
// Plans & billing (DATABASE-DESIGN.md §4)
// ============================================================================

// Seeded, not user-created (seed happens in S7-T1).
model Plan {
  id                      String       @id @default(uuid())
  code                    PlanCode
  name                    String
  priceInCents            Int          @map("price_in_cents")
  billingCycle            BillingCycle @map("billing_cycle")
  maxActiveProposals      Int          @map("max_active_proposals")
  maxDrivers              Int?         @map("max_drivers")
  extraDriverPriceInCents Int?         @map("extra_driver_price_in_cents")
  hasAdvancedAnalytics    Boolean      @default(false) @map("has_advanced_analytics")
  hasPriorityInSearch     Boolean      @default(false) @map("has_priority_in_search")
  hasVerifiedBadge        Boolean      @default(false) @map("has_verified_badge")
  hasFleetManagement      Boolean      @default(false) @map("has_fleet_management")
  hasMultiBranch          Boolean      @default(false) @map("has_multi_branch")

  subscriptions Subscription[]

  @@map("plan")
}

// subscriberId is polymorphic (User.id when subscriberType = CARRIER, or
// Company.id when subscriberType = COMPANY) — no FK constraint, same pattern
// as Turnora's AuditLog entityType/entityId.
model Subscription {
  id                 String             @id @default(uuid())
  subscriberType     SubscriberType     @map("subscriber_type")
  subscriberId       String             @map("subscriber_id")
  planId             String             @map("plan_id")
  status             SubscriptionStatus @default(ACTIVE)
  mpPreapprovalId    String?            @map("mp_preapproval_id")
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  gracePeriodEndsAt  DateTime?          @map("grace_period_ends_at")
  cancelledAt        DateTime?          @map("cancelled_at")
  createdAt          DateTime           @default(now()) @map("created_at")

  plan     Plan                  @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments SubscriptionPayment[]

  @@index([status, currentPeriodEnd])
  @@map("subscription")
}

// Individual payment records from Mercado Pago webhooks.
model SubscriptionPayment {
  id             String        @id @default(uuid())
  subscriptionId String        @map("subscription_id")
  amountInCents  Int           @map("amount_in_cents")
  status         PaymentStatus @default(PENDING)
  mpPaymentId    String?       @map("mp_payment_id")
  paidAt         DateTime?     @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscriptionPayment")
}

// ============================================================================
// Pricing engine (DATABASE-DESIGN.md §5.7-5.11)
// ============================================================================

// Base price for a corridor: origin cluster x destination cluster x shipment
// type x vehicle type.
model PricingTemplate {
  id                   String       @id @default(uuid())
  originClusterId      String       @map("origin_cluster_id")
  destinationClusterId String       @map("destination_cluster_id")
  shipmentType         ShipmentType @map("shipment_type")
  vehicleType          VehicleType  @map("vehicle_type")
  basePriceInCents     Int          @map("base_price_in_cents")
  isActive             Boolean      @default(true) @map("is_active")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  originCluster      NeighborhoodCluster @relation("PricingTemplateOrigin", fields: [originClusterId], references: [id], onDelete: Restrict)
  destinationCluster NeighborhoodCluster @relation("PricingTemplateDestination", fields: [destinationClusterId], references: [id], onDelete: Restrict)
  pricingSignals     PricingSignal[]
  pricingSnapshot    PricingSnapshot?

  @@unique([originClusterId, destinationClusterId, shipmentType, vehicleType])
  @@map("pricingTemplate")
}

// Incremental factors on top of base price. cityId = null means a global modifier.
model PricingModifier {
  id           String            @id @default(uuid())
  cityId       String?           @map("city_id")
  code         ModifierCode
  name         String
  valueType    ModifierValueType @map("value_type")
  valueInCents Int               @map("value_in_cents")
  isActive     Boolean           @default(true) @map("is_active")

  city City? @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@map("pricingModifier")
}

// Carrier or company's custom multiplier over a platform modifier.
model CarrierPricingConfig {
  id           String       @id @default(uuid())
  carrierId    String?      @map("carrier_id")
  companyId    String?      @map("company_id")
  modifierCode ModifierCode @map("modifier_code")
  multiplier   Decimal      @db.Decimal(4, 2)

  carrier User?    @relation(fields: [carrierId], references: [id], onDelete: Restrict)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("carrierPricingConfig")
}

// Immutable event log — never updated, only appended.
model PricingSignal {
  id           String     @id @default(uuid())
  templateId   String     @map("template_id")
  shipmentId   String?    @map("shipment_id")
  signalType   SignalType @map("signal_type")
  priceInCents Int        @map("price_in_cents")
  weight       Decimal    @db.Decimal(4, 3)
  createdAt    DateTime   @default(now()) @map("created_at")

  template PricingTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  shipment Shipment?       @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([templateId, createdAt])
  @@map("pricingSignal")
}

// Current calculated base price for a template corridor — rebuilt by the pricing engine.
model PricingSnapshot {
  id               String      @id @default(uuid())
  templateId       String      @unique @map("template_id")
  basePriceInCents Int         @map("base_price_in_cents")
  sampleSize       Int         @map("sample_size")
  lastTrigger      LastTrigger @map("last_trigger")
  calculatedAt     DateTime    @default(now()) @map("calculated_at")

  template PricingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("pricingSnapshot")
}

// ============================================================================
// Shipment — the core transaction (DATABASE-DESIGN.md §6)
// ============================================================================

model Shipment {
  id                    String         @id @default(uuid())
  customerId            String         @map("customer_id")
  status                ShipmentStatus @default(DRAFT)
  type                  ShipmentType
  description           String
  estimatedWeightKg     Decimal?       @map("estimated_weight_kg") @db.Decimal(8, 2)
  estimatedVolumeM3     Decimal?       @map("estimated_volume_m3") @db.Decimal(8, 2)
  requiredCategoryId    String?        @map("required_category_id")
  scheduledDate         DateTime       @map("scheduled_date") @db.Date
  timeWindow            TimeWindow     @map("time_window")
  specificTime          DateTime?      @map("specific_time") @db.Time
  suggestedPriceInCents Int            @map("suggested_price_in_cents")
  finalPriceInCents     Int?           @map("final_price_in_cents")
  collectionEtaMinutes  Int?           @map("collection_eta_minutes")
  deliveryEtaMinutes    Int?           @map("delivery_eta_minutes")
  windowExpiresAt       DateTime?      @map("window_expires_at")
  customerSlaHours      Int            @map("customer_sla_hours")
  collectedAt           DateTime?      @map("collected_at")
  inTransitAt           DateTime?      @map("in_transit_at")
  deliveredAt           DateTime?      @map("delivered_at")
  expiresAt             DateTime?      @map("expires_at")
  cancelledAt           DateTime?      @map("cancelled_at")
  cancelReason          String?        @map("cancel_reason")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  customer        CustomerProfile  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  requiredCategory VehicleCategory? @relation(fields: [requiredCategoryId], references: [id], onDelete: SetNull)

  addresses            ShipmentAddress[]
  modifiers            ShipmentModifier[]
  photos               ShipmentPhoto[]
  proposalQueueEntries ProposalQueueEntry[]
  proposals            Proposal[]
  chatRoom             ChatRoom?
  safetyCheckIns       SafetyCheckIn[]
  events               ShipmentEvent[]
  deliveryConfirmation DeliveryConfirmation?
  reviews              Review[]
  pricingSignals       PricingSignal[]

  @@index([customerId, status])
  @@index([status, scheduledDate])
  @@map("shipment")
}

// One ORIGIN and one DESTINATION per shipment.
model ShipmentAddress {
  id               String      @id @default(uuid())
  shipmentId       String      @map("shipment_id")
  type             AddressType
  street           String
  number           String
  complement       String?
  neighborhoodId   String?     @map("neighborhood_id")
  neighborhoodName String      @map("neighborhood_name")
  cityId           String      @map("city_id")
  state            String      @db.Char(2)
  zipCode          String      @map("zip_code")
  lat              Decimal?    @db.Decimal(10, 8)
  lng              Decimal?    @db.Decimal(11, 8)
  floor            Int?
  hasElevator      Boolean?    @map("has_elevator")

  shipment     Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  city         City          @relation(fields: [cityId], references: [id], onDelete: Restrict)

  @@unique([shipmentId, type])
  @@map("shipmentAddress")
}

// Selected modifiers for this specific shipment (snapshot of value at creation time).
model ShipmentModifier {
  id                  String       @id @default(uuid())
  shipmentId          String       @map("shipment_id")
  modifierCode        ModifierCode @map("modifier_code")
  quantity            Int          @default(1)
  appliedValueInCents Int          @map("applied_value_in_cents")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipmentModifier")
}

model ShipmentPhoto {
  id         String   @id @default(uuid())
  shipmentId String   @map("shipment_id")
  url        String
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipmentPhoto")
}

// ============================================================================
// Proposals & queue (DATABASE-DESIGN.md §7)
// ============================================================================

// Tracks carriers who expressed interest in a shipment (the FIFO queue).
model ProposalQueueEntry {
  id          String           @id @default(uuid())
  shipmentId  String           @map("shipment_id")
  carrierId   String           @map("carrier_id")
  status      QueueEntryStatus @default(WAITING)
  position    Int
  calledAt    DateTime?        @map("called_at")
  exhaustedAt DateTime?        @map("exhausted_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  shipment Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  carrier  User      @relation(fields: [carrierId], references: [id], onDelete: Restrict)
  proposal Proposal?

  @@unique([shipmentId, carrierId])
  @@index([shipmentId, position])
  @@map("proposalQueueEntry")
}

// One carrier's negotiation on one shipment. agreedSlaHours =
// ceil((customerSlaHours + carrierSlaHours) / 2) — calculated at the
// use-case layer.
model Proposal {
  id               String         @id @default(uuid())
  shipmentId       String         @map("shipment_id")
  carrierId        String         @map("carrier_id")
  queueEntryId     String         @unique @map("queue_entry_id")
  status           ProposalStatus @default(ACTIVE)
  currentAttempt   Int            @default(1) @map("current_attempt")
  customerSlaHours Int            @map("customer_sla_hours")
  carrierSlaHours  Int            @map("carrier_sla_hours")
  agreedSlaHours   Int            @map("agreed_sla_hours")
  expiresAt        DateTime       @map("expires_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  shipment   Shipment           @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  carrier    User               @relation(fields: [carrierId], references: [id], onDelete: Restrict)
  queueEntry ProposalQueueEntry @relation(fields: [queueEntryId], references: [id], onDelete: Cascade)
  attempts   ProposalAttempt[]

  @@unique([shipmentId, carrierId])
  @@index([carrierId, status])
  @@map("proposal")
}

// Each individual attempt within a proposal (up to 5).
model ProposalAttempt {
  id            String       @id @default(uuid())
  proposalId    String       @map("proposal_id")
  attemptNumber Int          @map("attempt_number")
  priceInCents  Int          @map("price_in_cents")
  message       String?
  proposedAt    DateTime     @default(now()) @map("proposed_at")
  respondedAt   DateTime?    @map("responded_at")
  responseType  ResponseType @default(PENDING) @map("response_type")

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("proposalAttempt")
}

// ============================================================================
// Chat (DATABASE-DESIGN.md §8)
// ============================================================================

// One room per shipment, created when the first proposal is submitted.
model ChatRoom {
  id         String   @id @default(uuid())
  shipmentId String   @unique @map("shipment_id")
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chatRoom")
}

model ChatMessage {
  id       String    @id @default(uuid())
  roomId   String    @map("room_id")
  senderId String    @map("sender_id")
  content  String
  sentAt   DateTime  @default(now()) @map("sent_at")
  readAt   DateTime? @map("read_at")

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([roomId, sentAt])
  @@map("chatMessage")
}

// ============================================================================
// Safety & transit (DATABASE-DESIGN.md §9)
// ============================================================================

// Shipment cannot transition to COLLECTED until both roles have confirmed —
// enforced at the use-case layer.
model SafetyCheckIn {
  id          String       @id @default(uuid())
  shipmentId  String       @map("shipment_id")
  userId      String       @map("user_id")
  role        ReviewerRole
  confirmedAt DateTime     @default(now()) @map("confirmed_at")
  ipAddress   String?      @map("ip_address") @db.Inet

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([shipmentId, role])
  @@map("safetyCheckIn")
}

// Immutable audit log of all events on a shipment. triggeredBy = null means
// a system event (e.g. auto-confirm after 24h).
model ShipmentEvent {
  id          String    @id @default(uuid())
  shipmentId  String    @map("shipment_id")
  eventType   EventType @map("event_type")
  triggeredBy String?   @map("triggered_by")
  occurredAt  DateTime  @default(now()) @map("occurred_at")
  metadata    Json?

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  trigger  User?    @relation(fields: [triggeredBy], references: [id], onDelete: SetNull)

  @@map("shipmentEvent")
}

// Customer's double-confirmation of delivery (Uber-style). If the customer
// doesn't respond within 24h, the system auto-confirms (use-case layer, via
// a shipmentEvent with triggeredBy = null).
model DeliveryConfirmation {
  id               String   @id @default(uuid())
  shipmentId       String   @unique @map("shipment_id")
  customerId       String   @map("customer_id")
  confirmed        Boolean
  issueDescription String?  @map("issue_description")
  confirmedAt      DateTime @default(now()) @map("confirmed_at")

  shipment Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  customer CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@map("deliveryConfirmation")
}

// ============================================================================
// Reviews (DATABASE-DESIGN.md §10)
// ============================================================================

// Mutual rating — one review per role per shipment. Tags only, no free text
// in v1. rating BETWEEN 1 AND 5 validated at the Zod schema layer (no DB CHECK).
model Review {
  id           String       @id @default(uuid())
  shipmentId   String       @map("shipment_id")
  reviewerId   String       @map("reviewer_id")
  revieweeId   String       @map("reviewee_id")
  reviewerRole ReviewerRole @map("reviewer_role")
  rating       Int
  createdAt    DateTime     @default(now()) @map("created_at")

  shipment      Shipment             @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  reviewer      User                 @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Restrict)
  reviewee      User                 @relation("ReviewSubject", fields: [revieweeId], references: [id], onDelete: Restrict)
  tagSelections ReviewTagSelection[]

  @@unique([shipmentId, reviewerRole])
  @@map("review")
}

// Predefined chips for both review directions (seeded in S4-T3).
model ReviewTag {
  id         String       @id @default(uuid())
  code       String       @unique
  label      String
  targetRole ReviewerRole @map("target_role")
  isActive   Boolean      @default(true) @map("is_active")

  selections ReviewTagSelection[]

  @@map("reviewTag")
}

model ReviewTagSelection {
  reviewId String @map("review_id")
  tagId    String @map("tag_id")

  review Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tag    ReviewTag @relation(fields: [tagId], references: [id], onDelete: Restrict)

  @@id([reviewId, tagId])
  @@map("reviewTagSelection")
}

// ============================================================================
// Notifications (DATABASE-DESIGN.md §11)
// ============================================================================

// Record of every notification sent (email or WhatsApp).
model NotificationLog {
  id                String                     @id @default(uuid())
  userId            String                     @map("user_id")
  channel           NotificationChannel
  templateCode      String                     @map("template_code")
  status            NotificationDeliveryStatus @default(PENDING)
  providerMessageId String?                    @map("provider_message_id")
  metadata          Json?
  sentAt            DateTime?                  @map("sent_at")
  createdAt         DateTime                   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, status, createdAt])
  @@map("notificationLog")
}
