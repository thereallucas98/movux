{
  "name": "web",
  "version": "0.1.0",
  "description": "Web application",
  "author": "David Lucas",
  "private": true,
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "dotenv -e .env -- tsx prisma/seed/geography.ts && dotenv -e .env -- tsx prisma/seed/pricing.ts && dotenv -e .env -- tsx prisma/seed/review-tags.ts",
    "dev": "next dev --port 3001",
    "build": "prisma generate && next build",
    "start": "next start",
    "prettier-format": "prettier --write src",
    "lint-fix": "eslint --fix src",
    "lint": "tsc --noEmit && eslint 'src/**/*.{ts,tsx}' --ignore-pattern 'src/generated' --max-warnings=0",
    "lint-check": "eslint src --ignore-pattern 'src/generated' --max-warnings=0",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test:unit": "vitest run --passWithNoTests",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test --project=mobile-webkit --project=tablet --project=desktop-chromium",
    "test:e2e:ui": "playwright test --project=mobile-webkit --project=tablet --project=desktop-chromium --ui",
    "test:e2e:install": "playwright install --with-deps chromium webkit",
    "test:api": "dotenv -e ../../.env.test -- playwright test --project=api --workers=1",
    "test:api:ui": "dotenv -e ../../.env.test -- playwright test --project=api --ui",
    "test:api:ci": "playwright test --project=api --workers=1"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-simple-objects": "^4.1.3",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-tooltip": "1.2.8",
    "@react-email/components": "1.0.12",
    "@supabase/supabase-js": "^2.105.0",
    "@tanstack/react-query": "5.90.21",
    "@movux/auth": "workspace:*",
    "@movux/env": "workspace:*",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "dotenv": "^16.4.5",
    "framer-motion": "^12.38.0",
    "graphql": "^16.12.0",
    "graphql-request": "^7.4.0",
    "graphql-yoga": "^5.21.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "0.564.0",
    "next": "16.1.6",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-day-picker": "9.13.2",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.1",
    "react-use-measure": "^2.1.7",
    "resend": "6.12.2",
    "sonner": "2.0.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-react": "^5.30.1",
    "tailwind-merge": "3.4.0",
    "tailwindcss-animate": "1.0.7",
    "zod": "4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@movux/env": "workspace:*",
    "@movux/eslint-config": "workspace:*",
    "@movux/prettier": "workspace:*",
    "@movux/tsconfig": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "25.2.3",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "autoprefixer": "10.4.24",
    "eslint": "^8.57.0",
    "lint-staged": "^16.2.7",
    "pg": "^8.20.0",
    "postcss": "8.5.6",
    "prisma": "^7.4.0",
    "react-email": "6.0.0",
    "tailwindcss": "4.1.18",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "src/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "prettier": "@movux/prettier"
}
