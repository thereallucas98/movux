    },
    {
      "_id": "jar_movux_s4_reviews_customer",
      "_type": "cookie_jar",
      "parentId": "wrk_movux_s4_reviews",
      "name": "Customer Jar",
      "cookies": []
    },
    {
      "_id": "req_submit_review",
      "_type": "request",
      "parentId": "wrk_movux_s4_reviews",
      "name": "Submit Review",
      "method": "POST",
      "url": "{{ _.base_url }}/api/shipments/{{ _.shipment_id }}/reviews",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"rating\": 5,\n  \"tagIds\": []\n}"
      },
      "cookieJar": "jar_movux_s4_reviews_customer"
    },
    {
      "_id": "req_list_reviews",
      "_type": "request",
      "parentId": "wrk_movux_s4_reviews",
      "name": "List Reviews",
      "method": "GET",
      "url": "{{ _.base_url }}/api/shipments/{{ _.shipment_id }}/reviews",
