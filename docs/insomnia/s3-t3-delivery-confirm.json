      "parentId": "wrk_movux_s3_delivery",
      "name": "Customer Jar",
      "cookies": []
    },
    {
      "_id": "req_confirm_delivery",
      "_type": "request",
      "parentId": "wrk_movux_s3_delivery",
      "name": "Confirm Delivery",
      "method": "POST",
      "url": "{{ _.base_url }}/api/shipments/{{ _.shipment_id }}/delivery-confirmation",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"confirmed\": true\n}"
      },
      "cookieJar": "jar_movux_s3_delivery_customer"
    },
    {
      "_id": "req_report_issue",
      "_type": "request",
      "parentId": "wrk_movux_s3_delivery",
      "name": "Report Delivery Issue",
      "method": "POST",
      "url": "{{ _.base_url }}/api/shipments/{{ _.shipment_id }}/delivery-confirmation",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"confirmed\": false,\n  \"issueDescription\": \"Caixa amassada\"\n}"
      },
      "cookieJar": "jar_movux_s3_delivery_customer"
    },
    {
      "_id": "req_get_delivery_status",
      "_type": "request",
      "parentId": "wrk_movux_s3_delivery",
      "name": "Get Delivery Confirmation Status",
      "method": "GET",
      "url": "{{ _.base_url }}/api/shipments/{{ _.shipment_id }}/delivery-confirmation",
      "headers": [],
      "cookieJar": "jar_movux_s3_delivery_customer"
    }
