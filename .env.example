NODE_ENV=development

# JWT — use a long random string, e.g. `openssl rand -hex 32`
JWT_SECRET=

# App
APP_URL="http://localhost:3001"

# Database (Docker Postgres — see docker-compose.yml)
DATABASE_URL="postgresql://postgres:docker@localhost:5442/turnora?schema=public"
DIRECT_URL="postgresql://postgres:docker@localhost:5442/turnora?schema=public"

# Email (Resend) — leave RESEND_API_KEY empty in dev to log emails to console
RESEND_API_KEY=
EMAIL_FROM="no-reply@turnora.app"

# ─────────────────────────────────────────────────────────────────────────────
# Test DB (optional — only needed for `pnpm --filter web test:api`)
# See .env.test for the values used by Playwright API tests.
# Start the test Postgres container via: `docker compose up -d turnora-test-postgres`
# ─────────────────────────────────────────────────────────────────────────────
