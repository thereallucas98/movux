NODE_ENV=test

# JWT — dummy value for tests (must be ≥ 32 chars)
JWT_SECRET="test-jwt-secret-32-chars-minimum-ok-value"

# App
APP_URL="http://localhost:3001"

# Database (test Postgres on port 5443 — see docker-compose.yml)
DATABASE_URL="postgresql://postgres:docker@localhost:5443/turnora_test?schema=public"
DIRECT_URL="postgresql://postgres:docker@localhost:5443/turnora_test?schema=public"

# Email — ConsoleClient fallback (never ship real emails during tests)
RESEND_API_KEY=
EMAIL_FROM="no-reply@turnora.app"
